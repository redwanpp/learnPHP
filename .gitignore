# Ignore system files
.DS_Store
Thumbs.db

# Composer dependencies
/vendor/

/composer.lock

# Node modules (if you are using frontend tools)
/node_modules/

/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*

# Logs and temporary files
*.log
*.cache
*.tmp
*.swp

# Symfony or Laravel specific (if applicable)
/bootstrap/cache/
/storage/logs/
/storage/framework/sessions/
/storage/framework/views/
/storage/framework/cache/

# PhpStorm specific files
.idea/
*.iml

# Docker-specific files
docker-compose.override.yml
docker-compose.override.yaml
docker/storage/mysql/*.sock
docker/storage/mysql/*.pid
docker/storage/mysql/*.log
/docker/storage/
/docker/nginx/

# Environment and sensitive files
.env
.env.*.local
.phpunit.result.cache

# Ignore test coverage reports
coverage/
.phpunit.cache/
tests/_output/

# Generated files
/public/hot
/public/storage
/public/build

# Ignore built assets
/build/
/dist/
*.map

# Ignore IDE-based settings for others
.vscode/

# Ignore system-specific metadata
*.bak
*.~*

# Ignore deployment and CI/CD related files
deploy/
.env.deploy.*

# Cache files
.cache/
